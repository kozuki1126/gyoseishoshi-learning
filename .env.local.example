# JWT認証用シークレットキー
# 重要: 本番環境では必ず強力なランダム文字列に変更してください
# 生成コマンド: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-super-secret-key-change-this-in-production

# 環境設定
NODE_ENV=development

# サイトURL（本番環境で変更）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# API ベースURL
API_BASE_URL=http://localhost:3000/api

# 管理者メールアドレス
ADMIN_EMAIL=admin@example.com

# 本番ビルド時に必要なデータベース URL
# DATABASE_URL=postgresql://username:password@localhost:5432/gyoseishoshi_db

# データベース設定（将来のSupabase連携用）
# SUPABASE_URL=your-supabase-url
# SUPABASE_ANON_KEY=your-supabase-anon-key
# SUPABASE_SERVICE_KEY=your-supabase-service-key

# 決済システム（将来のStripe連携用）
# STRIPE_PUBLIC_KEY=pk_test_xxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# メール送信設定（将来のメール認証用）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password

# Google Analytics（オプション）
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
